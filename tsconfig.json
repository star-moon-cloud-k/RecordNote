{
    "compilerOptions": {
        "target": "ES2022",
        "module": "ESNext",
        "moduleResolution": "Bundler",
        "lib": [
            "ES2022",
            "DOM"
        ],
        "strict": true,
        "noEmit": true,
        "skipLibCheck": true,
        "isolatedModules": true,
        "resolveJsonModule": true,
        "types": [
            "node"
        ],
        "jsx": "react-jsx"
    },
    "include": [
        "src",
        "forge.config.ts",
        "vite.*.config.ts",
        "vite.*.config.mts",
        "renderer/env.d.ts"
    ]
}